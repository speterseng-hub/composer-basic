# Copiar este archivo a .env antes de levantar docker compose.
# Valores por defecto para desarrollo local (no usar en producción).

AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=.

# Clave Fernet para encriptar conexiones/variables sensibles.
# Vacío = sin encriptación (suficiente para desarrollo local).
FERNET_KEY=

# Secreto para firmar tokens JWT de la API interna de Airflow 3 (dev only).
AIRFLOW__API_AUTH__JWT_SECRET=airflow_jwt_secret

# Usuario admin de la UI
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow